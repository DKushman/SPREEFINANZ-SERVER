/*Filter Plugin Customizations | Note: Suggestion to replace this with an Elementor Solution once that is available*/
.fe-ajo-custom .widget_wpc_filters_widget {
	margin-bottom: 0;	
}
.fe-ajo-custom .wpc-filters-widget-wrapper {
	display: grid;
	align-items: center;
	grid-column-gap: 20px;
	grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}
.fe-ajo-custom .wpc-filter-title {
	font-size: 16px;
	margin-bottom: 5px;
}
.fe-ajo-custom .select2.select2-container.select2-container--default {
    width: 100% !important;
}
.fe-ajo-custom .select2-container--default.select2-container--open .wpc-filter-everything-dropdown.select2-dropdown {
    border-color: #f1f7f9;
    padding-top: 0px;
}
.fe-ajo-custom .select2-search--dropdown .select2-search__field {
    padding: 7.5px 10px;
}
.fe-ajo-custom .select2-container--default .wpc-filter-everything-dropdown .select2-results__option--highlighted[aria-selected], .fe-ajo-custom .select2-container--default .wpc-filter-everything-dropdown .select2-results__option--highlighted[data-selected] {
    background-color: #45B9B9;
    color: #fff;
}
.fe-ajo-custom .select2-container--default .wpc-filter-everything-dropdown .select2-search--dropdown {
    padding: 10px;
}
.fe-ajo-custom .wpc-filter-layout-dropdown .select2-container--default .select2-selection--single, .fe-ajo-custom .wpc-sorting-form .select2-container--default .select2-selection--single {
    border-color: transparent;
    border-radius: 3px;
    padding: 7.55px 5px !important;
    background: #f1f7f9;
}

/*Mobile Icon*/
.fe-ajo-custom .widget-area .widget a.wpc-open-close-filters-button, .fe-ajo-custom .wpc-filters-open-widget, .fe-ajo-custom .wpc-open-close-filters-button, .fe-ajo-custom a.wpc-filters-open-widget, .fe-ajo-custom a.wpc-open-close-filters-button, body .fe-ajo-custom a.wpc-filters-open-widget, body .fe-ajo-custom a.wpc-open-close-filters-button {
	background: #f1f7f9;
	border-radius: 3px;
	border: transparent;
	padding: 10px 15px;
}

/*Filter Chips*/
.fe-ajo-custom #secondary .wpc-filter-chips-list li.wpc-filter-chip:not(.wpc-chip-reset-all) a, .widget-area .widget .wpc-filter-chips-list li.wpc-filter-chip:not(.wpc-chip-reset-all) a, body .wpc-filter-chips-list li.wpc-filter-chip:not(.wpc-chip-reset-all) a, body#colibri .wpc-filter-chips-list li.wpc-filter-chip:not(.wpc-chip-reset-all) a, .wpc-filter-chips-list li.wpc-filter-chip:not(.wpc-chip-reset-all) a {
    border-color: #45B9B9;
    background: #45B9B9;
    color: #fff;
	font-weight: 300;
}
.fe-ajo-custom .widget-area .widget .wpc-filter-chips-list .wpc-chip-reset-all a, body .wpc-filter-chips-list li.wpc-chip-reset-all a {
    border-color: #f1f7f9;
    background: #f1f7f9;
    color: red;
    font-weight: 300;
}
@media screen and (max-width: 768px) {
	.fe-ajo-custom .wpc-custom-selected-terms:not(.wpc-show-on-mobile) {
			display: block;
	}
}
.fe-ajo-custom .widget-area .widget ul.wpc-filter-chips-list, body ul.wpc-filter-chips-list {
    display: flex !important;
}
@media screen and (max-width: 768px) {
	.fe-ajo-custom .wpc-chip-remove-icon {
		display: block !important;
    font-size: 20px;
    line-height: 25px;
	}
	.fe-ajo-custom .wpc-chip-reset-all .wpc-filter-chip-name {
		display: none;
	}
}

.pum-overlay, html.pum-open.pum-open-overlay-disabled.pum-open-fixed .pum-container, html.pum-open.pum-open-overlay.pum-open-fixed .pum-container {
