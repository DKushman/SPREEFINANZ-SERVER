/* START: Simple Banner: Styling für Footer-Banner */
.simple-banner a.az-teaser__button {
    color: #00b9be !important;
    background-color: #fff !important;
}

.az-teaser__button {
	  padding: 5px 20px;
}

.simple-banner a:before {
    margin-right: 5px;
    display: inline-block;
    font-family: GeneratePress;
    content: "\f105";
}

.simple-banner a {
	margin-left: 10px;
}
/* END: Simple Banner: Styling für Footer-Banner */

/* WHV iframe breadcrumbs & prefooter ausblenden */
.page-id-51659 header.entry-header, .page-id-51659 section.pre-footer {
    display: none;
