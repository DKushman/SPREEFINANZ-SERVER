/* START: break menu items properly */
.main-navigation .main-nav ul li.menu-item-has-children>a {
    width: 100%;
    display: inline-flex;
    justify-content: space-between;
}
.main-navigation .main-nav ul li.menu-item-has-children>a {
    order: 1;
}
.main-navigation .main-nav ul li.menu-item-has-children>a span.label.label--xs.label--float-right {
    order: 2;
}
.main-navigation .main-nav ul li.menu-item-has-children>a span {
    order: 3;
}
/* END: break menu items properly */

