    <script type="text/javascript" id="clarity">

        function getCookieDomain() {
            const hostname = (window.location.hostname || '').toLowerCase();
            if (!isIP(hostname)) {
                return '.' + hostname.split('.').slice(-2).join('.');
            }
            return hostname;
        }

        function isIP(hostname) {
            // IPv4 & IPv6 regex
            return /(?:^(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}$)|(?:^(?:(?:[a-fA-F\d]{1,4}:){7}(?:[a-fA-F\d]{1,4}|:)|(?:[a-fA-F\d]{1,4}:){6}(?:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|:[a-fA-F\d]{1,4}|:)|(?:[a-fA-F\d]{1,4}:){5}(?::(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|(?::[a-fA-F\d]{1,4}){1,2}|:)|(?:[a-fA-F\d]{1,4}:){4}(?:(?::[a-fA-F\d]{1,4}){0,1}:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|(?::[a-fA-F\d]{1,4}){1,3}|:)|(?:[a-fA-F\d]{1,4}:){3}(?:(?::[a-fA-F\d]{1,4}){0,2}:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|(?::[a-fA-F\d]{1,4}){1,4}|:)|(?:[a-fA-F\d]{1,4}:){2}(?:(?::[a-fA-F\d]{1,4}){0,3}:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|(?::[a-fA-F\d]{1,4}){1,5}|:)|(?:[a-fA-F\d]{1,4}:){1}(?:(?::[a-fA-F\d]{1,4}){0,4}:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|(?::[a-fA-F\d]{1,4}){1,6}|:)|(?::(?:(?::[a-fA-F\d]{1,4}){0,5}:(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)(?:\\.(?:25[0-5]|2[0-4]\d|1\d\d|[1-9]\d|\d)){3}|(?::[a-fA-F\d]{1,4}){1,7}|:)))(?:%[0-9a-zA-Z]{1,})?$)/gm
                .test(hostname);
        }

        function setExpiryDateForCookie(cookieName) {
            if (document.cookie.indexOf(cookieName) !== -1) {
                var cookies = document.cookie.split(";");
                for (var i = 0; i < cookies.length; i++) {
                    var cookie = cookies[i];
                    cookie = cookie.trim();
                    if (cookie.indexOf(cookieName + "=") === 0) {
                        var expirationDate = new Date(0).toUTCString();
                        var domain = getCookieDomain();
                        document.cookie = cookieName + '=; expires=' + expirationDate + '; domain=' + domain + '; path=/';
                        cookies.splice(i, 1);
                        break;
                    }
                }
            }
        }

        //script exclusive for user that accept all the consent in the current page
        function getMarketingValue() {
            var cookiesKeys = document.cookie.split('; ');
            if (!cookiesKeys) {
                return 0;
            }

            var cookieConsentKeyValue = cookiesKeys.find((e) => e.includes('cookie_consent'));
            if (!cookieConsentKeyValue || cookieConsentKeyValue.length < 2 || !cookieConsentKeyValue.includes('=')) {
                return 0;
            }

            var cookieValues = cookieConsentKeyValue.split('=')[1];
            return JSON.parse(cookieValues).OfE;
        }

        function ucEventListener() {

            setTimeout(() => {
                var marketing = getMarketingValue();
                if (marketing !== 1) {
                    return;
                }

                window.clarity('start');
                window.clarity('consent');
            }, 1000);
        }

        window.addEventListener('ucEvents', ucEventListener);
        window.clarity('stop');
        setExpiryDateForCookie("_clck");
        setExpiryDateForCookie("_clsk");
        setExpiryDateForCookie("ANONCHK");
        setExpiryDateForCookie("CLID");
        setExpiryDateForCookie("SM");
        setExpiryDateForCookie("_cltk");
    </script>

